---
import { getCollection } from 'astro:content'
import { readFileSync, existsSync } from 'fs'
import { join, dirname } from 'path'
import { fileURLToPath } from 'url'

const posts = (await getCollection('posts'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const postCount = posts.length
const currentYear = new Date().getFullYear()
const base = import.meta.env.BASE_URL

// Try to read commit date, fall back to most recent post date
let lastUpdated: Date | undefined
const __dirname = dirname(fileURLToPath(import.meta.url))
const publicDir = join(__dirname, '..', 'public')
const dateFile = join(publicDir, '.last-commit-date.json')
if (existsSync(dateFile)) {
  const dateStr = JSON.parse(readFileSync(dateFile, 'utf-8')).date
  lastUpdated = new Date(dateStr)
}
if (!lastUpdated) {
  lastUpdated = posts[0]?.data.date
}
---

