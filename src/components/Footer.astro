          <a href={`${base}keys/publickey.naees.asc`} target="_blank" rel="noopener noreferrer">→ pgp key</a>
          <a href="https://signal.me/#eu/1Fkdlvu4vmAqdT-5QwGdGFH1b4uOrLlpyMlK8Fyr5aw_eu6XMJ1PEYOH18jG1nMY" target="_blank" rel="noopener noreferrer">→ signal</a>
        </nav>
      </div>

      <div class="footer-column">
        <h3 class="footer-column-title">Site</h3>
        <nav class="footer-nav" aria-label="Site navigation">
          <a href={`${base}#welcome`}>→ home</a>
          <a href={`${base}#open-source`}>→ open source</a>
          <a href={`${base}#pages`}>→ pages</a>
          <a href={`${base}posts/#hero`}>→ posts</a>
          <a href={`${base}posts/#search`}>→ search</a>
