---
import { getCollection } from 'astro:content'

const posts = (await getCollection('posts'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const postCount = posts.length
const lastUpdated = posts[0]?.data.date
const currentYear = new Date().getFullYear()
const base = import.meta.env.BASE_URL
---

<footer class="footer">
  <div class="container">
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href={`${base}/`}>→ home</a>
      <a href={`${base}/about/`}>→ about</a>
      <a href={`${base}/tags/`}>→ tags</a>
      <a href="https://github.com/Naees" target="_blank" rel="noopener noreferrer">→ github</a>
      <a href="https://keybase.io/Naees/pgp_keys.asc" target="_blank" rel="noopener noreferrer">→ pgp</a>
    </nav>
    <div class="footer-copy">
      &copy; {currentYear} naeeswrites · {postCount} posts · last updated {lastUpdated?.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
    </div>
  </div>
</footer>
