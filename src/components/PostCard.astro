---
interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  slug: string;
}

const { title, date, description, tags, slug } = Astro.props
const base = import.meta.env.BASE_URL
---

<article style="padding: 1.5rem 0; border-bottom: 1px solid var(--border);">
  <a href={`${base}/posts/${slug}/`} style="text-decoration: none; color: var(--text); display: block;">
    <h2 style="margin-top: 0; font-size: 1.5rem; letter-spacing: -0.02em;">{title}</h2>
  </a>
  <time style="color: var(--text-dim); font-size: 0.85rem; margin-bottom: 0.5rem; display: block;">
    {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
  </time>
  <p style="color: var(--text-dim); margin-bottom: 0.75rem;">{description}</p>
  <div class="post-tags-inline" style="font-family: var(--font-mono); font-size: 0.75rem;">
    {tags.map(tag => (
      <a href={`${base}/tags/${tag}/`} style="color: var(--text-dim); text-decoration-color: var(--text-muted); margin-right: 0.5rem;">
        #{tag}
      </a>
    ))}
  </div>
</article>
