---
import Layout from '../components/Layout.astro'
---

<Layout
  title="404 — Not Found"
  description="The page you are looking for does not exist."
  pathname="/404"
>

<div class="container error-404">
  <div style="max-width: 480px;">
    <!-- Eye-dot signature element -->
    <span class="eye-dot" style="display: block; margin-bottom: 1.5rem;"></span>

    <!-- Terminal: cat /dev/null -->
    <div class="prompt typing-line" style="margin-bottom: 1rem;">
      <span class="dollar">$</span> server ~ $ cat /dev/null<span class="cursor-blink">█</span>
    </div>
    <div class="divider" aria-hidden="true">~~~</div>

    <h1 style="margin-top: 0;">404</h1>
    <p style="color: var(--text-dim); font-size: 1.125rem; margin-top: 1rem; margin-bottom: 2rem;">
      The page you are looking for does not exist.
    </p>

    <a href="/" class="btn">
      ← go home
    </a>
  </div>
</div>

</Layout>
