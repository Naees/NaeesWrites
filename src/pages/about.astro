---
import Layout from '../components/Layout.astro'
---

<Layout
  title="About — NaeesWrites"
  description="About Naees, the author behind NaeesWrites."
  pathname="/about/"
>

<div class="container">

  <!-- Eye-dot signature element -->
  <span class="eye-dot" style="display: block; margin-bottom: 1rem;"></span>

  <!-- Terminal: whoami -->
  <div style="margin-bottom: 1.5rem;">
    <div class="prompt typing-line">
      <span class="dollar">$</span> naees@writes:~$ whoami<span class="cursor-blink">█</span>
    </div>
  </div>
  <div class="divider" aria-hidden="true">~~~</div>

  <p style="margin-bottom: 2rem;">
    naees — security researcher &amp; writer
  </p>

  <!-- Terminal: cat about.txt -->
  <div style="margin-top: 2rem;">
    <div class="prompt typing-line">
      <span class="dollar">$</span> naees@writes:~$ cat about.txt<span class="cursor-blink">█</span>
    </div>
  </div>
  <div class="divider" aria-hidden="true">~~~</div>

  <div class="output-block" style="border-left-color: var(--text-dim);">
I write about security, technology, and the things I find interesting along the way.
This blog is a space for thinking out loud, sharing ideas, and documenting what I learn.

When I'm not writing, I'm exploring new technologies, reading, or working on side projects.
  </div>

  <!-- Terminal: ls ~/contact/ -->
  <div style="margin-top: 2rem;">
    <div class="prompt typing-line">
      <span class="dollar">$</span> naees@writes:~$ ls ~/contact/<span class="cursor-blink">█</span>
    </div>
  </div>
  <div class="divider" aria-hidden="true">~~~</div>

  <nav style="padding-left: 1rem; margin-bottom: 2rem; display: flex; gap: 1.5rem; flex-wrap: wrap; font-family: var(--font-mono); font-size: 0.85rem;">
    <a href="https://github.com/Naees" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: var(--text-dim);">
      <span style="color: var(--accent);">→</span> github
    </a>
    <a href="https://linkedin.com/in/Naees" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: var(--text-dim);">
      <span style="color: var(--accent);">→</span> linkedin
    </a>
    <a href="https://twitter.com/Naees" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: var(--text-dim);">
      <span style="color: var(--accent);">→</span> x
    </a>
    <a href="mailto:naees@protonmail.com" style="text-decoration: none; color: var(--text-dim);">
      <span style="color: var(--accent);">→</span> naees@protonmail.com
    </a>
  </nav>

</div>

</Layout>
