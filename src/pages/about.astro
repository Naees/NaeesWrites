---
import Layout from '../components/Layout.astro'
import Divider from '../components/Divider.astro'
const base = import.meta.env.BASE_URL
---

<Layout
  title="About — NaeesWrites"
  description="About Naees, the author behind NaeesWrites — security researcher, writer, and co-author of a very good dog."
  pathname="/about/"
>

<div class="container" style="--about-base: '${base}';">

  <!-- Eye-dot signature element -->
  <span class="eye-dot" style="display: block; margin-bottom: 1.5rem;"></span>

  <!-- Split: Bio + Expertise -->
  <section id="bio" class="about-split">

    <div class="about-bio">
      <!-- Terminal: whoami -->
      <div style="margin-bottom: 1.5rem;">
      </div>

      <div class="about-bio-header">
        <img
          src={`${base}assets/kittenwiz_background_darkmode.svg`}
          alt="Naees profile"
          class="about-bio-photo"
        />
        <div>
          <div class="about-bio-name">naees — author</div>
          <div class="about-bio-title">security researcher &amp; writer</div>
        </div>
      </div>

      <p class="about-bio-label">naees — security researcher &amp; writer</p>

      <div class="output-block about-bio-text" style="border-left-color: var(--text-dim);">
I write about security, technology, and the things I find interesting along the way.
This blog is a space for thinking out loud, sharing ideas, and documenting what I learn.

When I'm not writing, I'm exploring new technologies, reading, or working on side projects.
      </div>
    </div>

    <div class="about-expertise">
      <h2 class="section-title">Expertise</h2>
      <!-- Terminal: cat expertise -->
      <div style="margin-bottom: 1.5rem;">
        <div class="prompt typing-line">
          <span class="dollar">$</span> naees@writes:~$ cat ~/expertise.txt<span class="cursor-blink">█</span>
        </div>
      </div>

      <div class="about-expertise-grid">
        <a class="about-expertise-pill" href={`${base}posts/?tag=web-security`}>Web Security</a>
        <a class="about-expertise-pill" href={`${base}posts/?tag=network-attacks`}>Network Attacks</a>
        <a class="about-expertise-pill" href={`${base}posts/?tag=privilege-escalation`}>Privilege Escalation</a>
        <a class="about-expertise-pill" href={`${base}posts/?tag=cryptography`}>Cryptography</a>
        <a class="about-expertise-pill" href={`${base}posts/?tag=cloud-security`}>Cloud Security</a>
        <a class="about-expertise-pill" href={`${base}posts/?tag=python`}>Scripting</a>
        <a class="about-expertise-pill" href={`${base}posts/?tag=exploit-development`}>Exploit Development</a>
        <a class="about-expertise-pill" href={`${base}posts/?tag=security-automation`}>Security Automation</a>
        <a class="about-expertise-pill" href={`${base}posts/?tag=linux`}>Linux Administration</a>
        <a class="about-expertise-pill" href={`${base}posts/?tag=incident-response`}>Incident Response</a>
        <a class="about-expertise-pill" href={`${base}posts/?tag=security`}>Security</a>
        <a class="about-expertise-pill" href={`${base}posts/?tag=philosophy`}>philosophy</a>
      </div>
    </div>

  </section>

  <Divider />

  <!-- Research Highlights -->
  <section id="highlights">
    <h2 class="section-title">Research</h2>
    <div style="margin-bottom: 1.5rem;">
      <div class="prompt typing-line">
        <span class="dollar">$</span> naees@writes:~$ ls ~/research/<span class="cursor-blink">█</span>
      </div>
    </div>

    <div class="about-highlights-grid">
      <a href={`${base}posts/minimalism-security/`} class="about-highlight-card">
        <div class="about-highlight-title">On Minimalism in Security Research</div>
        <div class="about-highlight-desc">Why less is more when it comes to understanding attack surfaces.</div>
      </a>
      <a href={`${base}posts/threat-modeling/`} class="about-highlight-card">
        <div class="about-highlight-title">Threat Modeling for Small Teams</div>
        <div class="about-highlight-desc">A practical approach to threat modeling that doesn't require a dedicated security team.</div>
      </a>
      <a href={`${base}posts/ethics-privacy/`} class="about-highlight-card">
        <div class="about-highlight-title">The Ethics of Privacy in the Digital Age</div>
        <div class="about-highlight-desc">Exploring the tension between security and privacy in modern systems.</div>
      </a>
    </div>
  </section>

  <Divider />

  <!-- PGP Public Key -->
  <section id="pgp">
    <h2 class="section-title">PGP Public Key</h2>
    <p class="section-subtitle">For encrypted email correspondence, please use my key below.
      You can verify the key with the listed fingerprint.
    </p>

    <div class="output-block about-pgp-block" style="border-left-color: var(--accent);">key fingerprint: 
      EE03 DCB4 E594 D725 C528  83E0 4BCC B80F BFB5 EE54
    </div>

    <div style="margin-top: 1rem; display: flex; gap: 1rem; flex-wrap: wrap;">
      <a href={`${base}keys/publickey.naees.asc`} class="btn" download>
        download .asc
      </a>
    </div>
  </section>

  <Divider />

  <!-- Signal -->
  <section id="signal">
    <h2 class="section-title">Signal</h2>
    <p class="section-subtitle">Want to reach out, have something important to share. Hit me up on Signal.</p>
    <div style="margin-top: 1rem;">
      <a href="https://signal.me/#eu/1Fkdlvu4vmAqdT-5QwGdGFH1b4uOrLlpyMlK8Fyr5aw_eu6XMJ1PEYOH18jG1nMY" class="btn" target="_blank" rel="noopener noreferrer">
      message me here
      </a>
    </div>
  </section>

  <Divider />

  <!-- Contact -->
  <section id="contact">
    <h2 class="section-title">Contact</h2>
    <p class="section-subtitle">Got a question, a project, or just want to say hi? Here's how to find me.</p>

    <nav class="about-contact-grid" aria-label="Contact links">
      <a href="https://github.com/Naees" target="_blank" rel="noopener noreferrer" class="about-contact-link">
        <span class="about-contact-arrow">→</span> github
      </a>
      <a href="https://linkedin.com/in/Naees" target="_blank" rel="noopener noreferrer" class="about-contact-link">
        <span class="about-contact-arrow">→</span> linkedin
      </a>
      <a href="https://twitter.com/Naees" target="_blank" rel="noopener noreferrer" class="about-contact-link">
        <span class="about-contact-arrow">→</span> x
      </a>
      <a href="mailto:naees@protonmail.com" class="about-contact-link">
        <span class="about-contact-arrow">→</span> naees@protonmail.com
      </a>
      <a href={`${base}keys/publickey.naees.asc`} target="_blank" rel="noopener noreferrer" class="about-contact-link">
        <span class="about-contact-arrow">→</span> pgp key
      </a>
      <a href="https://signal.me/#eu/1Fkdlvu4vmAqdT-5QwGdGFH1b4uOrLlpyMlK8Fyr5aw_eu6XMJ1PEYOH18jG1nMY" target="_blank" rel="noopener noreferrer" class="about-contact-link">
        <span class="about-contact-arrow">→</span> signal
      </a>
    </nav>
  </section>

  <Divider />

  <!-- Co-Author: Haku -->
  <section id="haku" class="about-haku-section">
    <div style="margin-bottom: 1.5rem;">
      <div class="prompt typing-line">
        <span class="dollar">$</span> naees@writes:~$ cat ~/co-author.md<span class="cursor-blink">█</span>
      </div>
    </div>

    <div class="about-haku-split">
      <div class="about-haku-left">
        <div class="about-haku-header">
          <img
            src={`${base}assets/haku.jpg`}
            alt="Haku, the good boy"
            class="about-haku-photo"
          />
          <div>
            <div class="about-haku-name">haku — co-author</div>
            <div class="about-haku-title">senior security analyst (canine division)</div>
          </div>
        </div>

        <div class="about-haku-bio">
          <div class="output-block about-haku-text" style="border-left-color: var(--text-dim);">
Clearance level:  ████████░░ 80%
Badge of honor:    Good boy

Haku doesn't write the posts — but they do provide excellent
incident response coverage. Their primary responsibilities include
sniffing out security vulnerabilities (literally), performing
physical penetration testing on the front door, and conducting
thorough code reviews by sitting on the keyboard.

Notable achievements:
- Successfully defended the couch against 3 cat intrusions
- Discovered a critical vulnerability in the treat-dispensing API
- Authored 0 blog posts, but has given excellent feedback

"I don't understand the terminal. I understand the tone of
voice that says 'sit.' That is the only exploit I need."
— haku, senior analyst

Status:  [●] on duty (sleeping)
          </div>
        </div>
      </div>

      <div class="about-haku-img">
        <img
          src={`${base}assets/raincoat_haku.jpg`}
          alt="Haku in a raincoat"
          class="about-haku-img-photo"
        />
      </div>
    </div>
  </section>

</div>

</Layout>
