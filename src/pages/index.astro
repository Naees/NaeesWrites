---
import Layout from '../components/Layout.astro'
const base = import.meta.env.BASE_URL
---

<Layout
  title="NaeesWrites — Welcome"
  description="Welcome to NaeesWrites. An open blog about security, technology, design, and philosophy."
  pathname="/"
>

<div class="container">

  <!-- Hero -->
  <div class="hero" style="margin-bottom: 3rem;">
    <h1 style="margin-top: 0;">Welcome<span class="eye-dot"></span></h1>
    <p>Thanks for stopping by. This is a space for thinking out loud.</p>
  </div>

  <div class="divider" aria-hidden="true">~~~</div>

  <!-- Terminal prompt -->
  <div style="margin-bottom: 1.5rem;">
    <div class="prompt typing-line" style="margin-bottom: 0.5rem;">
      <span class="dollar">$</span> naees@writes:~/blog$ cat welcome.md
      <span class="cursor-blink">█</span>
    </div>
  </div>

  <!-- Welcome / disclaimer -->
  <div class="open-source-box" style="margin-bottom: 2.5rem;">
    <div class="prompt" style="margin-bottom: 1rem;">
      <span class="dollar">$</span> naees@writes:~/blog$ cat DISCLAIMER.md
    </div>
    <p style="color: var(--text-dim); max-width: 540px; margin-bottom: 1rem;">
      This blog is <strong style="color: var(--text);">open source</strong> — you can find the source code, report bugs, or suggest improvements on GitHub. If you spot something broken or have an idea for a new feature, don't hesitate to open an issue or pull request.
    </p>
    <a href="https://github.com/Naees/NaeesWrites" class="terminal-link" style="display: inline-block;">
      <span class="dollar">$</span> open https://github.com/Naees/NaeesWrites
    </a>
  </div>

  <div class="divider" aria-hidden="true">~~~</div>

  <!-- Terminal prompt -->
  <div style="margin-bottom: 1.5rem;">
    <div class="prompt typing-line" style="margin-bottom: 0.5rem;">
      <span class="dollar">$</span> naees@writes:~/blog$ ls -la /pages/
      <span class="cursor-blink">█</span>
    </div>
  </div>

  <!-- Page navigation boxes -->
  <div class="page-grid" style="margin-bottom: 2.5rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem;">

    <a href={`${base}posts/`} class="page-card" style="text-decoration: none; color: inherit;">
      <div class="page-card-header">
        <div class="prompt" style="margin: 0;">
          <span class="dollar">$</span> ls posts/
        </div>
      </div>
      <p class="page-card-body">
        Browse all blog posts — security, technology, design, and philosophy.
      </p>
    </a>

    <a href={`${base}about/`} class="page-card" style="text-decoration: none; color: inherit;">
      <div class="page-card-header">
        <div class="prompt" style="margin: 0;">
          <span class="dollar">$</span> cat about.md
        </div>
      </div>
      <p class="page-card-body">
        Learn more about me, my background, and what I write about.
      </p>
    </a>

    <a href={`${base}tags/`} class="page-card" style="text-decoration: none; color: inherit;">
      <div class="page-card-header">
        <div class="prompt" style="margin: 0;">
          <span class="dollar">$</span> find . -type tag
        </div>
      </div>
      <p class="page-card-body">
        Explore posts organized by topic — filter by tags and categories.
      </p>
    </a>

  </div>

  <div class="divider" aria-hidden="true">~~~</div>

  <!-- Terminal prompt: cat -->
  <div style="margin-bottom: 1.5rem;">
    <div class="prompt" style="margin-bottom: 0.5rem;">
      <span class="dollar">$</span> naees@writes:~/blog$ echo "Happy reading!"
    </div>
  </div>

</div>

<style>
  .open-source-box {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
  }
  .terminal-link {
    color: var(--accent);
    text-decoration: none;
    font-family: 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .terminal-link:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }
  .page-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    transition: border-color 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
  }
  .page-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .page-card-header .prompt {
    margin-bottom: 0.75rem;
  }
  .page-card-body {
    color: var(--text-dim);
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.5;
  }
  @media (max-width: 640px) {
    .page-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

</Layout>
