---
import { getCollection } from 'astro:content'
import { slugify, getReadingTime } from '../../lib/utils'
import Layout from '../../components/Layout.astro'
import Divider from '../../components/Divider.astro'
import GiscusComments from '../../components/GiscusComments.astro'

const base = import.meta.env.BASE_URL

export async function getStaticPaths() {
  const posts = await getCollection('posts')
  return posts.map(post => ({
    params: { slug: post.id },
  }))
}

const { slug } = Astro.params
const allPosts = await getCollection('posts')
const postEntry = allPosts.find(p => p.id === slug)
const post = postEntry?.data
const body = postEntry?.body

if (!post) {
  throw new Error('Post not found: ' + slug)
}
---

<Layout
  title={post.title + ' — NaeesWrites'}
  description={post.description}
  pathname={'/posts/' + slug + '/'}
  publishedTime={post.date.toISOString()}
  type="article"
>

<!-- Reading progress bar -->
<div class="reading-progress" aria-hidden="true">
  <div class="reading-progress-bar" id="reading-progress-bar"></div>
</div>

<div class="container">

  <!-- Terminal: cat post -->
  <div class="prompt typing-line">
    <span class="dollar">$</span> naees@writes:~/blog$ cat posts/{slug}.md<span class="cursor-blink">█</span>
  </div>
  <Divider />

  <!-- Meta -->
  <div class="post-meta">
    {post.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    &nbsp;&nbsp;·&nbsp;&nbsp;{getReadingTime(postEntry!.body)} min read
  </div>

  <h1 style="font-size: 2.5rem; margin-top: 0.5rem; margin-bottom: 0.5rem; font-family: Georgia, 'Times New Roman', Times, serif; font-weight: 700; letter-spacing: -0.02em; line-height: 1.2;">{post.title}</h1>

  <Divider />

  <!-- Body -->
  <div class="post-body">
    {body}
  </div>

  <Divider />

  <!-- Tags -->
  {post.tags && post.tags.length > 0 && (
    <div class="post-tags-pill">
      {post.tags.map(tag => (
        <a href={`${base}posts/?tag=${encodeURIComponent(tag)}`} class="tag-pill">
          {tag}
        </a>
      ))}
    </div>
  )}

  <!-- Comments -->
  <div class="prompt" style="margin-bottom: 1.5rem;">
    <span class="dollar">$</span> naees@writes:~/blog$ ./comments.sh
  </div>
  <div style="margin-top: 1rem;">
    <GiscusComments currentSlug={slug} />
  </div>

</div>

<script>
  const progressBar = document.getElementById('reading-progress-bar')
  if (progressBar) {
    function updateProgress() {
      const scrollTop = window.scrollY
      const docHeight = document.documentElement.scrollHeight - window.innerHeight
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0
      progressBar.style.width = progress + '%'
    }
    window.addEventListener('scroll', updateProgress, { passive: true })
    updateProgress()
  }
</script>

</Layout>
