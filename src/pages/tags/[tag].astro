---
import { getCollection } from 'astro:content'
import { getAllTags, slugify } from '../../lib/utils'
import Tag from '../../components/Tag.astro'
import PostCard from '../../components/PostCard.astro'
import Layout from '../../components/Layout.astro'
import DarkModeToggle from '../../components/DarkModeToggle.astro'

export async function getStaticPaths() {
  const posts = await getCollection('posts')
  const allTags = getAllTags(posts)
  return allTags.map(tag => ({
    params: { tag: slugify(tag) },
  }))
}

const { tag } = Astro.params
const allPosts = await getCollection('posts')
const posts = allPosts
  .filter(post => {
    const postTags = post.data.tags || []
    return !post.data.draft && postTags.map(t => slugify(t)).includes(tag)
  })
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<Layout
  title={'Posts tagged "' + tag + '" — NaeesWrites'}
  description={'Posts about ' + tag}
  pathname={'/tags/' + tag + '/'}
>
  <div slot="darkModeToggle"><DarkModeToggle /></div>

  <div class="container">
    <div style="margin-bottom: 3rem;">
      <a href="/tags/" style="font-size: 0.875rem; color: var(--text-secondary); text-decoration: none; margin-bottom: 1rem; display: inline-block;">
        &larr; All tags
      </a>
      <h1 style="margin-top: 0.5rem;">{tag}</h1>
      <p style="color: var(--text-secondary);">
        {posts.length} post{posts.length !== 1 ? 's' : ''}
      </p>
    </div>

    {posts.map(post => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        description={post.data.description}
        tags={post.data.tags || []}
        slug={post.id}
      />
    ))}
  </div>
</Layout>
